pipeline {
    agent {
        kubernetes {
            yaml '''
apiVersion: v1
kind: Pod
spec:
  containers:
  - name: nodejs
    image: node:24.5.0
    command: ['sleep']
    args: ['infinity']
'''
        }
    }
    stages {
        stage('build') {
            when {
                changeset "**/result/**"
            }
            steps {
                container('nodejs') {
                    echo 'Compiling result app..'
                    dir('result') {
                        sh 'npm install'
                    }
                }
            }
        }
        
        stage('test') {
            when {
                changeset '**/result/**'
            }
            steps {
                container('nodejs') {
                    echo 'Running Unit Tests on result app..'
                    dir('result') {
                        sh '''npm install
                              npm test'''
                    }
                }
            }
        }
    }
}
